@page "/registro"
@layout Layout.MainLayout
@rendermode InteractiveServer
@using FluentValidation
@using Sitram.Application.Auth.Commands.Registrar
@inject ISender Sender
@inject NavigationManager Navigation

<PageTitle>Crear cuenta — SITRAM</PageTitle>

<div class="auth-page">
    <div class="auth-card">
        <div style="text-align:center;margin-bottom:1.4rem">
            <div style="width:58px;height:58px;border-radius:17px;background:var(--brand);color:var(--on-brand);display:flex;align-items:center;justify-content:center;margin:0 auto 0.9rem;box-shadow:0 6px 18px rgba(11,92,74,0.35)">
                <Icon Name="user" Size="27" />
            </div>
            <div style="font-weight:800;font-size:1.14rem;letter-spacing:-0.015em">Crea tu cuenta de ciudadano</div>
            <div style="font-size:0.76rem;color:var(--ink-faint);margin-top:0.28rem">Tus datos se protegen según la Ley 29733</div>
        </div>

        @if (_errores.Count > 0)
        {
            <div class="alert alert-danger">
                <Icon Name="alert" Size="16" />
                <span>
                    @foreach (var e in _errores)
                    {
                        <div>@e</div>
                    }
                </span>
            </div>
        }

        <label class="field-label" for="r-nombres">Nombres</label>
        <div class="field-wrap"><Icon Name="user" Size="15" /><input class="field" id="r-nombres" @bind="_nombres" /></div>

        <label class="field-label" for="r-apellidos">Apellidos</label>
        <div class="field-wrap"><Icon Name="user" Size="15" /><input class="field" id="r-apellidos" @bind="_apellidos" /></div>

        <label class="field-label" for="r-dni">DNI (8 dígitos)</label>
        <div class="field-wrap"><Icon Name="shield" Size="15" /><input class="field" id="r-dni" inputmode="numeric" maxlength="8" @bind="_dni" /></div>

        <label class="field-label" for="r-email">Correo electrónico</label>
        <div class="field-wrap"><Icon Name="bell" Size="15" /><input class="field" id="r-email" type="email" @bind="_email" /></div>

        <label class="field-label" for="r-telefono">Teléfono</label>
        <div class="field-wrap"><Icon Name="bell" Size="15" /><input class="field" id="r-telefono" @bind="_telefono" /></div>

        <label class="field-label" for="r-direccion">Dirección</label>
        <div class="field-wrap"><Icon Name="house" Size="15" /><input class="field" id="r-direccion" @bind="_direccion" /></div>

        <label class="field-label" for="r-user">Nombre de usuario</label>
        <div class="field-wrap"><Icon Name="user" Size="15" /><input class="field" id="r-user" autocomplete="username" @bind="_userName" /></div>

        <label class="field-label" for="r-pass">Contraseña (mínimo 8: mayúscula, minúscula y dígito)</label>
        <div class="field-wrap"><Icon Name="lock" Size="15" /><input class="field" id="r-pass" type="password" autocomplete="new-password" @bind="_password" /></div>

        <button class="btn btn-primary" style="margin-top:0.4rem" disabled="@_procesando" @onclick="RegistrarAsync">
            @(_procesando ? "Creando cuenta…" : "Crear cuenta") <Icon Name="chev" Size="15" />
        </button>

        <div class="card" style="text-align:center;font-size:0.78rem;color:var(--ink-soft);margin-top:0.8rem">
            ¿Ya tienes cuenta? <a href="/login" style="color:var(--brand-deep);font-weight:700">Inicia sesión</a>
        </div>

        <div class="trust-row">
            <Icon Name="lock" Size="12" />
            Conexión segura · Ley 29733 de protección de datos
        </div>
    </div>
</div>

@code {
    private string _nombres = "";
    private string _apellidos = "";
    private string _dni = "";
    private string _email = "";
    private string _telefono = "";
    private string _direccion = "";
    private string _userName = "";
    private string _password = "";
    private bool _procesando;
    private readonly List<string> _errores = new();

    private async Task RegistrarAsync()
    {
        _errores.Clear();
        _procesando = true;
        try
        {
            await Sender.Send(new RegistrarCiudadanoCommand(
                _userName.Trim(), _email.Trim(), _password,
                _nombres.Trim(), _apellidos.Trim(), _dni.Trim(), _telefono.Trim(), _direccion.Trim()));

            Navigation.NavigateTo(
                "/login?exito=" + Uri.EscapeDataString("Cuenta creada. Revisa tu correo para verificarla y luego inicia sesión."),
                forceLoad: true);
        }
        catch (ValidationException ex)
        {
            _errores.AddRange(ex.Errors.Select(e => e.ErrorMessage).Distinct());
        }
        catch (Exception)
        {
            _errores.Add("No se pudo crear la cuenta. Inténtalo de nuevo en unos minutos.");
        }
        finally
        {
            _procesando = false;
        }
    }
}
