@page "/"
@rendermode InteractiveServer
@attribute [Authorize(Policy = "TramiteConsultar")]
@inject ISender Sender
@inject ICurrentUserService CurrentUser

<PageTitle>Mis trámites — SITRAM</PageTitle>

@if (_cargando)
{
    <p>Cargando…</p>
}
else
{
    <div style="display:flex;align-items:center;gap:0.72rem;margin-bottom:1.05rem">
        <div style="width:44px;height:44px;border-radius:50%;background:var(--brand);color:var(--on-brand);display:flex;align-items:center;justify-content:center;font-weight:800;font-size:0.9rem;flex-shrink:0;box-shadow:0 0 0 3px var(--brand-soft)">
            @Iniciales
        </div>
        <div>
            <p style="font-size:0.7rem;color:var(--ink-faint);margin:0">Hola de nuevo</p>
            <p style="font-size:1.05rem;font-weight:800;margin:0.04rem 0 0;letter-spacing:-0.01em">@NombreCompleto</p>
        </div>
    </div>

    <div style="display:flex;gap:0.55rem;margin-bottom:0.3rem">
        <div class="card" style="flex:1;text-align:center;padding:0.6rem 0.5rem;margin-bottom:0">
            <div style="font-size:1.25rem;font-weight:800">@_activos.Count</div>
            <div style="font-size:0.58rem;color:var(--ink-faint);font-weight:700;text-transform:uppercase">Activos</div>
        </div>
        <div class="card" style="flex:1;text-align:center;padding:0.6rem 0.5rem;margin-bottom:0">
            <div style="font-size:1.25rem;font-weight:800;color:var(--gold)">@_atencion.Count</div>
            <div style="font-size:0.58rem;color:var(--ink-faint);font-weight:700;text-transform:uppercase">Atención</div>
        </div>
        <div class="card" style="flex:1;text-align:center;padding:0.6rem 0.5rem;margin-bottom:0">
            <div style="font-size:1.25rem;font-weight:800;color:var(--brand)">@_finalizados.Count(t => t.Estado == "Aprobado")</div>
            <div style="font-size:0.58rem;color:var(--ink-faint);font-weight:700;text-transform:uppercase">Aprobados</div>
        </div>
    </div>

    @if (_atencion.Count > 0)
    {
        <div class="section-title">Requiere tu atención</div>
        @foreach (var t in _atencion)
        {
            <TramiteCard Tramite="t" Alerta="true" />
        }
    }

    @if (_activos.Count > 0)
    {
        <div class="section-title">En trámite</div>
        @foreach (var t in _activos)
        {
            <TramiteCard Tramite="t" />
        }
    }

    @if (_borradores.Count > 0)
    {
        <div class="section-title">Borradores</div>
        @foreach (var t in _borradores)
        {
            <TramiteCard Tramite="t" />
        }
    }

    @if (_finalizados.Count > 0)
    {
        <div class="section-title">Finalizados</div>
        @foreach (var t in _finalizados)
        {
            <TramiteCard Tramite="t" />
        }
    }

    @if (_todos.Count == 0)
    {
        <div class="card" style="text-align:center;padding:2rem 1rem">
            <p style="font-weight:700;margin:0 0 0.3rem">Aún no tienes trámites</p>
            <p class="card-sub" style="margin-bottom:1rem">Inicia el primero cuando quieras — el catálogo TUPA muestra la tasa antes de empezar.</p>
            <a href="/tramites/nuevo" class="btn btn-primary" style="width:auto;display:inline-flex;padding:0.6rem 1.2rem">Nuevo trámite</a>
        </div>
    }
}

@code {
    private bool _cargando = true;
    private string NombreCompleto = "";
    private string Iniciales = "";
    private List<Sitram.Application.Tramites.Queries.ListarTramitesCiudadano.TramiteResumenDto> _todos = new();
    private List<Sitram.Application.Tramites.Queries.ListarTramitesCiudadano.TramiteResumenDto> _atencion = new();
    private List<Sitram.Application.Tramites.Queries.ListarTramitesCiudadano.TramiteResumenDto> _activos = new();
    private List<Sitram.Application.Tramites.Queries.ListarTramitesCiudadano.TramiteResumenDto> _borradores = new();
    private List<Sitram.Application.Tramites.Queries.ListarTramitesCiudadano.TramiteResumenDto> _finalizados = new();

    protected override async Task OnInitializedAsync()
    {
        var ciudadanoId = CurrentUser.UsuarioId!.Value;

        var perfil = await Sender.Send(new Sitram.Application.Ciudadanos.Queries.ObtenerPerfilCiudadano.ObtenerPerfilCiudadanoQuery(ciudadanoId));
        if (perfil is not null)
        {
            NombreCompleto = $"{perfil.Nombres} {perfil.Apellidos}";
            Iniciales = $"{perfil.Nombres[0]}{perfil.Apellidos[0]}".ToUpperInvariant();
        }

        var pagina = await Sender.Send(new Sitram.Application.Tramites.Queries.ListarTramitesCiudadano.ListarTramitesCiudadanoQuery(ciudadanoId, 1, 50));
        _todos = pagina.Items.ToList();
        _atencion = _todos.Where(t => t.Estado is "Observado").ToList();
        _activos = _todos.Where(t => t.Estado is "Recibido" or "EnRevision").ToList();
        _borradores = _todos.Where(t => t.Estado is "Borrador").ToList();
        _finalizados = _todos.Where(t => t.Estado is "Aprobado" or "Rechazado").ToList();

        _cargando = false;
    }
}
