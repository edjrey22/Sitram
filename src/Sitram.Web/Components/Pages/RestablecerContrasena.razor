@page "/restablecer-contrasena"
@layout Layout.MainLayout
@rendermode InteractiveServer
@using FluentValidation
@using Sitram.Application.Auth.Commands.RestablecerContrasena
@inject ISender Sender
@inject NavigationManager Navigation

<PageTitle>Restablecer contraseña — SITRAM</PageTitle>

<div class="auth-page">
    <div class="auth-card">
        <div style="text-align:center;margin-bottom:1.8rem">
            <div style="width:58px;height:58px;border-radius:17px;background:var(--brand);color:var(--on-brand);display:flex;align-items:center;justify-content:center;margin:0 auto 0.9rem;box-shadow:0 6px 18px rgba(11,92,74,0.35)">
                <Icon Name="shield" Size="27" />
            </div>
            <div style="font-weight:800;font-size:1.14rem;letter-spacing:-0.015em">Elige tu nueva contraseña</div>
            <div style="font-size:0.76rem;color:var(--ink-faint);margin-top:0.28rem">
                Mínimo 8 caracteres, con mayúscula, minúscula y dígito
            </div>
        </div>

        @if (UsuarioId == Guid.Empty || string.IsNullOrWhiteSpace(Token))
        {
            <div class="alert alert-danger">
                <Icon Name="alert" Size="16" />
                <span>El enlace está incompleto. Solicita uno nuevo desde <a href="/recuperar-contrasena">recuperar contraseña</a>.</span>
            </div>
        }
        else
        {
            @if (_error is not null)
            {
                <div class="alert alert-danger"><Icon Name="alert" Size="16" /><span>@_error</span></div>
            }

            <label class="field-label" for="rs-pass">Nueva contraseña</label>
            <div class="field-wrap">
                <Icon Name="lock" Size="15" />
                <input class="field" id="rs-pass" type="password" autocomplete="new-password" @bind="_password" />
            </div>

            <label class="field-label" for="rs-pass2">Repite la contraseña</label>
            <div class="field-wrap">
                <Icon Name="lock" Size="15" />
                <input class="field" id="rs-pass2" type="password" autocomplete="new-password" @bind="_confirmacion" />
            </div>

            <button class="btn btn-primary" disabled="@_procesando" @onclick="RestablecerAsync">
                @(_procesando ? "Guardando…" : "Restablecer contraseña") <Icon Name="chev" Size="15" />
            </button>
        }

        <div class="trust-row">
            <Icon Name="lock" Size="12" />
            Conexión segura · Ley 29733 de protección de datos
        </div>
    </div>
</div>

@code {
    [SupplyParameterFromQuery(Name = "usuarioId")]
    public Guid UsuarioId { get; set; }

    [SupplyParameterFromQuery(Name = "token")]
    public string? Token { get; set; }

    private string _password = "";
    private string _confirmacion = "";
    private bool _procesando;
    private string? _error;

    private async Task RestablecerAsync()
    {
        _error = null;

        if (_password != _confirmacion)
        {
            _error = "Las contraseñas no coinciden.";
            return;
        }

        _procesando = true;
        try
        {
            await Sender.Send(new RestablecerContrasenaCommand(UsuarioId, Token!, _password));
            Navigation.NavigateTo(
                "/login?exito=" + Uri.EscapeDataString("Contraseña restablecida. Ya puedes iniciar sesión."),
                forceLoad: true);
        }
        catch (ValidationException ex)
        {
            _error = string.Join(" ", ex.Errors.Select(e => e.ErrorMessage).Distinct());
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _procesando = false;
        }
    }
}
