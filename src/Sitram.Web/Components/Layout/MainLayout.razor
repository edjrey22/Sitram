@inherits LayoutComponentBase

<div class="app-shell">
    <header class="topbar">
        <a class="brand" href="/">
            <span class="crest"><Icon Name="building" Size="18" /></span>
            <div>
                <div class="wordmark">SITRAM</div>
                <div class="sub">Trámites municipales</div>
            </div>
        </a>
        <AuthorizeView>
            <Authorized>
                <div class="topbar-actions">
                    <NavLink href="/notificaciones" class="icon-btn" title="Notificaciones">
                        <Icon Name="bell" Size="16" />
                    </NavLink>
                    <form method="post" action="/auth/logout">
                        <button type="submit" class="icon-btn" title="Cerrar sesión">
                            <Icon Name="logout" Size="16" />
                        </button>
                    </form>
                </div>
            </Authorized>
        </AuthorizeView>
    </header>

    <div class="app-body">
        <AuthorizeView>
            <Authorized>
                <nav class="side-nav">
                    <NavLink href="/" Match="NavLinkMatch.All"><Icon Name="home" Size="16" /> Mis trámites</NavLink>
                    <NavLink href="/tramites/nuevo"><Icon Name="plus" Size="16" /> Nuevo trámite</NavLink>
                    <NavLink href="/notificaciones"><Icon Name="bell" Size="16" /> Notificaciones</NavLink>
                </nav>
            </Authorized>
        </AuthorizeView>

        <main class="content">
            @Body
        </main>
    </div>

    <AuthorizeView>
        <Authorized>
            <nav class="bottom-nav">
                <NavLink href="/" Match="NavLinkMatch.All"><Icon Name="home" Size="20" /><span>Inicio</span></NavLink>
                <NavLink href="/tramites/nuevo"><Icon Name="file" Size="20" /><span>Trámites</span></NavLink>
                <NavLink href="/notificaciones"><Icon Name="bell" Size="20" /><span>Avisos</span></NavLink>
                <NavLink href="/perfil"><Icon Name="user" Size="20" /><span>Perfil</span></NavLink>
            </nav>
        </Authorized>
    </AuthorizeView>
</div>

<div id="blazor-error-ui" data-nosnippet>
    Ha ocurrido un error inesperado.
    <a href="." class="reload">Recargar</a>
    <span class="dismiss">🗙</span>
</div>

